<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_batch_planning_wizard_line_list" model="ir.ui.view">
        <field name="name">mrp.batch.planning.wizard.line.list</field>
        <field name="model">mrp.batch.planning.wizard.line</field>
        <field name="arch" type="xml">
            <list string="Planlama Satırları" editable="bottom" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="workcenter_id" readonly="1" string="Kalıp"/>
                <field name="production_ids" widget="many2many_tags" options="{'no_create': True}" string="Üretim Emirleri"/>
                <field name="product_names" string="Ürün Detayları"/>
                <field name="allowed_workcenter_ids" column_invisible="1"/>
                <field name="total_length_usage" string="Kullanılan Boy (cm)" readonly="1"/>
                <field name="time_mode" width="100px" string="Döküm Sayısı"/>
                <field name="date_start" string="Başlangıç" readonly="1" force_save="1"/>
                <field name="date_finished" string="Bitiş" readonly="1" force_save="1"/>
            </list>
        </field>
    </record>

    <record id="view_mrp_batch_planning_wizard_form" model="ir.ui.view">
        <field name="name">mrp.batch.planning.wizard.form</field>
        <field name="model">mrp.batch.planning.wizard</field>
        <field name="arch" type="xml">
            <form string="Toplu Planlama - Kalıp Seçimi">
                <sheet>
                    <!-- Gizli Alanlar -->
                    <group invisible="1">
                        <field name="scheduled_date"/>
                        <field name="available_mo_ids" force_save="1"/>
                        <field name="available_workcenter_ids" force_save="1"/>
                        <field name="filtered_mo_ids" force_save="1"/>
                        <field name="previous_workcenter_id" force_save="1"/>
                        <field name="used_mo_ids" force_save="1"/>
                    </group>

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- BÖLÜM 1: KALIP SEÇİMİ + MEVCUT PLANLAMALAR       -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <div class="row mb-3">
                        <div class="col-12">
                            <div class="alert alert-info mb-0 py-2" role="alert">
                                <strong>📋 Kalan Üretim Emri:</strong>
                                <field name="remaining_mo_count" readonly="1" class="fw-bold"/>
                            </div>
                        </div>
                    </div>

                    <group>
                        <group string="🔧 Kalıp Ekle">
                            <field name="selected_workcenter_id" string="Kalıp Seç" options="{'no_create': True}"/>
                            <field name="workcenter_date_start" string="Başlangıç Tarihi"/>
                            <div class="mt-2">
                                <button name="action_add_workcenter"
                                        string="➕ Kalıba Ekle"
                                        type="object"
                                        class="btn-primary btn-lg"
                                        invisible="not selected_workcenter_id"/>
                            </div>
                        </group>
                        <group string="📅 Kalıptaki Mevcut Planlamalar" invisible="not selected_workcenter_id">
                            <field name="existing_plan_info" nolabel="1" colspan="2" readonly="1"/>
                        </group>
                    </group>

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- BÖLÜM 2: BU KALIBA UYGUN ÜRÜNLER                 -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <group string="📦 Bu Kalıba Uygun Ürünler" invisible="not selected_workcenter_id">
                        <field name="step2_product_group_ids" nolabel="1">
                            <list editable="bottom" create="false" decoration-info="selected_count > 0">
                                <field name="product_id" readonly="1" force_save="1" string="Ürün"/>
                                <field name="diameter_width" readonly="1" force_save="1" string="En (cm)"/>
                                <field name="height" readonly="1" force_save="1" string="Boy (cm)"/>
                                <field name="available_mo_count" readonly="1" string="Bekleyen"/>
                                <field name="selected_count" string="Planlanacak" force_save="1"/>
                                <field name="total_length" readonly="1" string="Seçilen Uzunluk"/>
                                <field name="mo_ids" column_invisible="1" force_save="1"/>
                            </list>
                        </field>
                    </group>

                    <!-- ═══════════════════════════════════════════════════ -->
                    <!-- BÖLÜM 3: KALIP PLANLAMALARI (EKLENEN GRUPLAR)     -->
                    <!-- ═══════════════════════════════════════════════════ -->
                    <separator string="🗂️ Kalıp Planlamaları" invisible="not workcenter_group_ids"/>
                    <field name="workcenter_group_ids" nolabel="1" widget="one2many" invisible="not workcenter_group_ids">
                        <list create="false" decoration-success="production_count > 0">
                            <field name="workcenter_id" readonly="1" force_save="1" string="Kalıp"/>
                            <field name="date_start" string="Başlangıç Tarihi"/>
                            <field name="production_count" readonly="1" string="Üretim Emri"/>
                            <field name="workcenter_capacity" readonly="1" string="Kapasite (cm)"/>
                        </list>
                        <form string="Kalıp Detayı">
                            <sheet>
                                <div class="oe_title mb-3">
                                    <h2>
                                        <field name="workcenter_id" readonly="1" force_save="1"/>
                                    </h2>
                                </div>
                                <group>
                                    <group string="📋 Bilgiler">
                                        <field name="date_start" string="Başlangıç Tarihi"/>
                                        <field name="production_count" readonly="1" string="Üretim Emri Sayısı"/>
                                        <field name="workcenter_capacity" readonly="1" string="Kalıp Kapasitesi (cm)"/>
                                    </group>
                                </group>

                                <!-- Kullanılabilir Üretim Emirleri -->
                                <notebook>
                                    <page string="📥 Eklenebilir Üretim Emirleri">
                                        <field name="available_for_placement_ids" nolabel="1" readonly="1">
                                            <list>
                                                <field name="name" string="Üretim Emri"/>
                                                <field name="product_id" string="Ürün"/>
                                                <field name="en" string="En (cm)"/>
                                                <field name="boy" string="Boy (cm)"/>
                                                <field name="uzunluk" string="Uzunluk (cm)"/>
                                            </list>
                                        </field>
                                    </page>
                                </notebook>

                                <separator string="📋 Üretim Emirleri"/>
                                <field name="line_ids" nolabel="1">
                                    <list editable="bottom" decoration-danger="capacity_exceeded == True" default_order="sequence">
                                        <field name="sequence" widget="handle"/>
                                        <field name="production_ids"
                                               widget="many2many_tags"
                                               domain="[('id', 'in', parent.dropdown_mo_ids)]"
                                               options="{'no_create': True}"
                                               string="Üretim Emirleri"/>
                                        <field name="product_names" string="Ürün Detayları"/>
                                        <field name="time_mode" string="Döküm Sayısı"/>
                                        <field name="total_length_usage" string="Uzunluk (cm)" readonly="1"/>
                                        <field name="capacity_status" string="Durum" readonly="1"/>
                                        <field name="date_start" string="Başlangıç" readonly="1" force_save="1"/>
                                        <field name="date_finished" string="Bitiş" readonly="1" force_save="1"/>
                                        <field name="capacity_exceeded" column_invisible="1"/>
                                        <field name="line_capacity" column_invisible="1"/>
                                    </list>
                                </field>
                            </sheet>
                        </form>
                    </field>

                    <!-- Eski batch_line_ids (backward compatibility) -->
                    <group invisible="workcenter_group_ids or remaining_mo_count">
                        <field name="batch_line_ids"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm"
                            string="✅ Planlamayı Onayla"
                            type="object"
                            class="btn-primary btn-lg"
                            invisible="not workcenter_group_ids"/>
                    <button string="İptal" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
