<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- mrp.workcenter.tag Editable Tree View -->
    <record id="mrp_workcenter_tag_view_list" model="ir.ui.view">
        <field name="name">mrp.workcenter.tag.list</field>
        <field name="model">mrp.workcenter.tag</field>
        <field name="arch" type="xml">
            <list string="Work Center Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- mrp.workcenter.tag Form View -->
    <record id="mrp_workcenter_tag_view_form" model="ir.ui.view">
        <field name="name">mrp.workcenter.tag.form</field>
        <field name="model">mrp.workcenter.tag</field>
        <field name="arch" type="xml">
            <form string="Work Center Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="mrp_workcenter_tag_action" model="ir.actions.act_window">
        <field name="name">İş Merkezi Etiketleri</field>
        <field name="res_model">mrp.workcenter.tag</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Yeni bir iş merkezi etiketi oluşturun
          </p>
          <p>
            Etiketleri iş merkezlerini gruplamak veya kategorize etmek için kullanabilirsiniz.
            Ayrıca bu ekran üzerinden mevcut etiketlerin ismini veya rengini silmeye gerek kalmadan değiştirebilirsiniz.
          </p>
        </field>
    </record>

    <!-- Menu Item (Under Manufacturing -> Configuration) -->
    <menuitem id="menu_mrp_workcenter_tag"
              action="mrp_workcenter_tag_action"
              parent="mrp.menu_mrp_configuration"
              sequence="30"/>

</odoo>
