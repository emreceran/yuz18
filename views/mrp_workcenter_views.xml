<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_workcenter_view_form_inherit_capacity" model="ir.ui.view">
        <field name="name">mrp.workcenter.view.form.inherit.capacity</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='capacity']" position="after">
                <group string="Kalıp Kapasite Ölçüleri">
                    <field name="x_width_capacity" string="En Kapasitesi (Width)"/>
                    <field name="x_height_capacity" string="Boy Kapasitesi (Height)"/>
                    <field name="x_max_length_capacity" string="Maksimum Uzunluk"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
