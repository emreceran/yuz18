<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_workcenter_view_form_inherit_capacity" model="ir.ui.view">
        <field name="name">mrp.workcenter.view.form.inherit.capacity</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
        <field name="arch" type="xml">
            <!-- Alternatif İş Merkezleri gizle -->
            <xpath expr="//field[@name='alternative_workcenter_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Çalışma Saatleri gizle -->
            <xpath expr="//field[@name='resource_calendar_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Üretim Bilgisi grubunu gizle -->
            <xpath expr="//group[@name='capacity']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Maliyetlendirme Bilgisi grubunu gizle -->
            <xpath expr="//group[@name='costing']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Spesifik Kapasiteler tabını gizle -->
            <xpath expr="//page[@name='capacity']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//group[@name='capacity']" position="after">
                <group string="Konum">
                    <field name="x_hall"/>
                </group>
                <group string="Kalıp Kapasite Ölçüleri">
                    <field name="x_width_capacity" string="En Kapasitesi (Width)"/>
                    <field name="x_height_capacity" string="Boy Kapasitesi (Height)"/>
                    <field name="x_max_length_capacity" string="Maksimum Uzunluk"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

